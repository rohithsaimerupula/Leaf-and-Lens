# ────────────────────────────────────────────────────────────────
#  LEAF & LENS — FIREBASE CONFIGURATION TEMPLATE
# ────────────────────────────────────────────────────────────────
# To store registrations, photo uploads, and reel submissions in a
# shared central database, follow these steps:
#
# 1. Create a free Firebase project at: https://console.firebase.google.com/
# 2. Enable "Cloud Firestore" and "Firebase Storage" in your Firebase console.
# 3. Create a Web App within your Firebase project to get these keys.
# 4. Create a copy of this file, rename it to ".env.local", and paste your keys below.
# 5. Restart your development server. The portal will automatically switch to Firestore!

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
